{
  "_meta": {
    "version": "1.0",
    "description": "Cérebro do OrquestradorAPK — erros conhecidos e suas correções. Cresce automaticamente a cada novo erro resolvido.",
    "total_fixes_applied": 3,
    "last_updated": "2026-06-20"
  },
  "fixes": [
    {
      "id": "just_audio_repeatmode",
      "description": "just_audio usa LoopMode, não RepeatMode do Flutter",
      "error_patterns": [
        "Member not found: 'off'",
        "Member not found: 'one'",
        "Member not found: 'all'",
        "RepeatMode",
        "not exhaustively matched"
      ],
      "context_patterns": [
        "just_audio",
        "RepeatMode"
      ],
      "type": "regex_replace",
      "operations": [
        {
          "find": "\\bRepeatMode\\.off\\b",
          "replace": "LoopMode.off"
        },
        {
          "find": "\\bRepeatMode\\.one\\b",
          "replace": "LoopMode.one"
        },
        {
          "find": "\\bRepeatMode\\.all\\b",
          "replace": "LoopMode.all"
        },
        {
          "find": "\\bRepeatMode\\b",
          "replace": "LoopMode"
        }
      ],
      "ensure_imports": [
        "import 'package:just_audio/just_audio.dart';"
      ],
      "explanation": "just_audio >= 0.9 usa LoopMode em vez de RepeatMode do Flutter framework",
      "times_applied": 0,
      "source": "manual"
    },
    {
      "id": "just_audio_seturl_removed",
      "description": "AudioPlayer.setUrl() foi removido no just_audio >= 0.9",
      "error_patterns": [
        "setUrl",
        "Method not found: 'setUrl'"
      ],
      "context_patterns": [
        "just_audio",
        ".setUrl("
      ],
      "type": "info_only",
      "operations": [],
      "fix_hint": "Substitua: player.setUrl(url)  →  player.setAudioSource(AudioSource.uri(Uri.parse(url)))",
      "explanation": "setUrl() foi removido. Use AudioSource.uri() como fonte de áudio",
      "times_applied": 0,
      "source": "manual"
    },
    {
      "id": "shared_preferences_await",
      "description": "SharedPreferences.getX() é síncrono desde v2.x — await desnecessário",
      "error_patterns": [
        "await prefs.get",
        "The await expression can only be used in an async"
      ],
      "context_patterns": [
        "shared_preferences",
        "await prefs.get"
      ],
      "type": "regex_replace",
      "operations": [
        {
          "find": "await (prefs\\.get\\w+\\([^)]*\\))",
          "replace": "\\1"
        }
      ],
      "explanation": "SharedPreferences v2+ tornou getters síncronos. Remover await.",
      "times_applied": 0,
      "source": "manual"
    },
    {
      "id": "missing_pubspec_deps",
      "description": "Pacotes usados no código não declarados no pubspec.yaml",
      "error_patterns": [
        "Couldn't resolve the package",
        "Not found: 'package:",
        "Target of URI doesn't exist"
      ],
      "context_patterns": [
        "import 'package:"
      ],
      "type": "pubspec_inject",
      "operations": [],
      "explanation": "Detectar imports e injetar dependências automaticamente no pubspec.yaml",
      "times_applied": 1,
      "source": "manual"
    },
    {
      "id": "switch_exhaustive_loopmode",
      "description": "Switch em LoopMode sem case default — erro de exhaustiveness Dart 3",
      "error_patterns": [
        "not exhaustively matched",
        "doesn't match 'LoopMode.restart'",
        "doesn't match 'RepeatMode.restart'"
      ],
      "context_patterns": [
        "switch",
        "LoopMode"
      ],
      "type": "add_default_case",
      "operations": [],
      "fix_hint": "Adicionar 'default: break;' no switch de LoopMode (via contagem de chaves)",
      "explanation": "Dart 3 exige exhaustiveness em switch. LoopMode tem valor .restart que precisa de case. Corrigido via parser linha a linha com contagem de chaves.",
      "times_applied": 0,
      "source": "manual"
    },
    {
      "id": "media_store_not_exists",
      "description": "Pacote 'media_store' não existe no pub.dev — substituir por 'on_audio_query'",
      "error_patterns": [
        "Couldn't resolve the package 'media_store'",
        "Not found: 'package:media_store",
        "media_store"
      ],
      "context_patterns": [
        "media_store"
      ],
      "type": "import_replace",
      "operations": [
        {
          "find": "import 'package:media_store/media_store.dart';",
          "replace": "import 'package:on_audio_query/on_audio_query.dart';"
        },
        {
          "find": "import \"package:media_store/media_store.dart\";",
          "replace": "import \"package:on_audio_query/on_audio_query.dart\";"
        }
      ],
      "pubspec_replace": {
        "media_store": "on_audio_query: ^2.9.0"
      },
      "fix_hint": "media_store não existe. Use on_audio_query para acessar a MediaStore do Android.",
      "explanation": "O pacote 'media_store' nunca existiu no pub.dev. O equivalente correto é 'on_audio_query' que fornece acesso à MediaStore do Android com API Dart nativa.",
      "times_applied": 1,
      "source": "manual"
    },
    {
      "id": "build_version_sdk_int",
      "description": "Build.VERSION.SDK_INT é Java/Kotlin — não existe em Dart",
      "error_patterns": [
        "Build",
        "Undefined name 'Build'",
        "SDK_INT"
      ],
      "context_patterns": [
        "Build.VERSION.SDK_INT"
      ],
      "type": "regex_replace",
      "operations": [
        {
          "find": "if \\(Build\\.VERSION\\.SDK_INT >= (\\d+)\\) \\{[^}]+\\}",
          "replace": "// Verificação de versão Android via device_info_plus"
        }
      ],
      "fix_hint": "Use DeviceInfoPlugin().androidInfo.then((info) => info.version.sdkInt >= N)",
      "explanation": "Build.VERSION.SDK_INT é API Java/Android SDK. Em Dart/Flutter use device_info_plus: final info = await DeviceInfoPlugin().androidInfo; if (info.version.sdkInt >= 33)",
      "times_applied": 1,
      "source": "manual"
    },
    {
      "id": "android_gradle_namespace",
      "description": "Android Gradle Plugin exige namespace em build.gradle de plugins antigos",
      "error_patterns": [
        "Namespace not specified",
        "Specify a namespace in the module's build file",
        "LibraryVariantBuilderImpl"
      ],
      "context_patterns": [
        "build.gradle",
        "android"
      ],
      "type": "android_gradle_fix",
      "operations": [],
      "fix_hint": "O orquestrador irá adicionar automaticamente namespace ao build.gradle do plugin problemático",
      "explanation": "Plugins Android antigos não têm namespace declarado no build.gradle, exigido pelo Android Gradle Plugin 8.0+. O orquestrador detecta e corrige automaticamente adicionando namespace baseado no package do AndroidManifest.xml",
      "times_applied": 0,
      "source": "manual"
    },
