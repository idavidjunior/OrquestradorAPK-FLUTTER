{
  "_meta": {
    "version": "1.0",
    "description": "Cérebro do OrquestradorAPK — erros conhecidos e suas correções. Cresce automaticamente a cada novo erro resolvido.",
    "total_fixes_applied": 0,
    "last_updated": "2026-06-19"
  },
  "fixes": [
    {
      "id": "just_audio_repeatmode",
      "description": "just_audio usa LoopMode, não RepeatMode do Flutter",
      "error_patterns": [
        "Member not found: 'off'",
        "Member not found: 'one'",
        "Member not found: 'all'",
        "RepeatMode",
        "not exhaustively matched"
      ],
      "context_patterns": ["just_audio", "RepeatMode"],
      "type": "regex_replace",
      "operations": [
        {"find": "\\bRepeatMode\\.off\\b",  "replace": "LoopMode.off"},
        {"find": "\\bRepeatMode\\.one\\b",  "replace": "LoopMode.one"},
        {"find": "\\bRepeatMode\\.all\\b",  "replace": "LoopMode.all"},
        {"find": "\\bRepeatMode\\b",         "replace": "LoopMode"}
      ],
      "ensure_imports": ["import 'package:just_audio/just_audio.dart';"],
      "explanation": "just_audio >= 0.9 usa LoopMode em vez de RepeatMode do Flutter framework",
      "times_applied": 0,
      "source": "manual"
    },
    {
      "id": "just_audio_seturl_removed",
      "description": "AudioPlayer.setUrl() foi removido no just_audio >= 0.9",
      "error_patterns": [
        "setUrl",
        "Method not found: 'setUrl'"
      ],
      "context_patterns": ["just_audio", ".setUrl("],
      "type": "info_only",
      "operations": [],
      "fix_hint": "Substitua: player.setUrl(url)  →  player.setAudioSource(AudioSource.uri(Uri.parse(url)))",
      "explanation": "setUrl() foi removido. Use AudioSource.uri() como fonte de áudio",
      "times_applied": 0,
      "source": "manual"
    },
    {
      "id": "shared_preferences_await",
      "description": "SharedPreferences.getX() é síncrono desde v2.x — await desnecessário",
      "error_patterns": [
        "await prefs.get",
        "The await expression can only be used in an async"
      ],
      "context_patterns": ["shared_preferences", "await prefs.get"],
      "type": "regex_replace",
      "operations": [
        {"find": "await (prefs\\.get\\w+\\([^)]*\\))", "replace": "\\1"}
      ],
      "explanation": "SharedPreferences v2+ tornou getters síncronos. Remover await.",
      "times_applied": 0,
      "source": "manual"
    },
    {
      "id": "missing_pubspec_deps",
      "description": "Pacotes usados no código não declarados no pubspec.yaml",
      "error_patterns": [
        "Couldn't resolve the package",
        "Not found: 'package:",
        "Target of URI doesn't exist"
      ],
      "context_patterns": ["import 'package:"],
      "type": "pubspec_inject",
      "operations": [],
      "explanation": "Detectar imports e injetar dependências automaticamente no pubspec.yaml",
      "times_applied": 0,
      "source": "manual"
    },
    {
      "id": "switch_exhaustive_loopmode",
      "description": "Switch em LoopMode sem case default — erro de exhaustiveness Dart 3",
      "error_patterns": [
        "not exhaustively matched",
        "doesn't match 'LoopMode.restart'",
        "doesn't match 'RepeatMode.restart'"
      ],
      "context_patterns": ["switch", "LoopMode"],
      "type": "add_default_case",
      "operations": [],
      "fix_hint": "Adicionar 'default: break;' no switch de LoopMode",
      "explanation": "Dart 3 exige exhaustiveness em switch. LoopMode tem valor .restart que precisa de case",
      "times_applied": 0,
      "source": "manual"
    }
  ],
